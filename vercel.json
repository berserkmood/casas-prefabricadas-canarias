{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*.html",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/guias/:path*/",
      "destination": "/guias/index.html"
    },
    {
      "source": "/guias/:path*",
      "destination": "/guias/:path*.html"
    }
  ]
}